# ─── Base de Dados ───
# Instância local PostgreSQL (já criada)
DATABASE_URL="postgresql://postgres:root@localhost:5432/GameHubPessoal?schema=public"

# ─── Redis ───
REDIS_URL="redis://localhost:6379"

# ─── APIs Externas ───
RAWG_API_KEY="your_rawg_api_key_here"
STEAM_API_KEY="your_steam_api_key_here"
IGDB_CLIENT_ID=""
IGDB_CLIENT_SECRET=""

# ─── Servidor ───
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
CORS_ALLOWED_ORIGINS="http://localhost:5173"
SESSION_COOKIE_NAME="gh_session"
SESSION_TTL_DAYS=30

# ─── SMTP (Recuperacao de Senha) ───
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_gmail@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_FROM="your_gmail@gmail.com"
SMTP_SECURE=false
SMTP_RESET_BASE_URL="http://localhost:5173/reset-password"

# ─── Frontend ───
VITE_API_URL="http://localhost:3001"
